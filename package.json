{
  "name": "indigo",
  "private": true,
  "version": "0.0.1",
  "description": "Indigo — AI-First Construction Management Platform for Good Guy Builders",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:portal": "pnpm --filter portal dev",
    "build": "pnpm --filter web build",
    "build:portal": "pnpm --filter portal build",
    "build:all": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
