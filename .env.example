# Supabase — get from https://supabase.com/dashboard/project/fueksflgmkruauanhgzx/settings/api
VITE_SUPABASE_URL=https://fueksflgmkruauanhgzx.supabase.co
VITE_SUPABASE_ANON_KEY=

# HERE Maps — address autocomplete + geofence geocoding.
# Used server-side by the Netlify function — no domain restrictions needed.
# Free tier at developer.here.com (250k transactions/month free).
# Add this to Netlify → Site configuration → Environment variables.
HERE_API_KEY=

# Optional dev fallback: uncomment to call HERE directly from the browser
# when running `pnpm dev` (skips the Netlify function).
# The key must allow localhost in its domain allowlist for this to work.
# VITE_HERE_API_KEY=


# Public app URL — used for auth redirect links (magic links, portal invites).
# Set this to your deployed domain so invite emails link to the real app, not
# to whatever localhost the PM happens to be running.
# e.g. https://app.yourdomain.com  (no trailing slash)
VITE_APP_URL=

# AI Providers (server-side only — Netlify functions)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Stripe (server-side only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Twilio (server-side only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
